{
  "builds": [
    {
      "src": "api/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "buildCommand": "mkdir -p logs && python manage.py collectstatic --noinput"
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "api/wsgi.py" }
  ]
}
