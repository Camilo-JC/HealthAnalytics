# =============================================
# HealthAnalytics IPS - Variables de Entorno
# Copia este archivo a .env y completa los valores
# =============================================

# ---- Django ----
DJANGO_SECRET_KEY=tu-clave-secreta-muy-larga-y-aleatoria
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=.vercel.app,.onrender.com,localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings
DJANGO_SITE_URL=https://tu-api.vercel.app

# ---- Base de Datos (Neon PostgreSQL) ----
# Opción 1: URL completa (recomendado para Neon/Render)
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Opción 2: Variables individuales (alternativa local)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=healthcare_etl
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=localhost
# DB_PORT=5432

# ---- CORS (Frontend URL desplegado en Vercel) ----
# Agrega la URL exacta de tu frontend en Vercel
CORS_ALLOWED_ORIGINS=https://tu-app.vercel.app

# ---- Celery / Redis (Opcional - sin Redis funciona en modo síncrono) ----
# Si no tienes Redis, CELERY_TASK_ALWAYS_EAGER=True ejecuta las tareas sincrónicamente
CELERY_TASK_ALWAYS_EAGER=True
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---- JWT ----
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ---- Admin Inicial (Creado automáticamente al iniciar) ----
ADMIN_EMAIL=admin@healthanalytics.com
ADMIN_PASSWORD=Admin123!Seguro

# ---- ETL ----
ETL_UPLOAD_MAX_SIZE_MB=50
ETL_CHUNK_SIZE=500
ETL_DEFAULT_ENCODING=utf-8

# ---- ML ----
ML_MODEL_PATH=models/
ML_RANDOM_STATE=42
ML_TEST_SIZE=0.2
ML_CV_FOLDS=5

# ---- Email (Opcional) ----
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu_correo@gmail.com
EMAIL_HOST_PASSWORD=tu_app_password_gmail

# ---- Logging ----
LOG_LEVEL=INFO
LOG_DIR=logs/

# ---- Gunicorn (Render) ----
WEB_CONCURRENCY=1
PORT=8000
