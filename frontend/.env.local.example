# ============================================
# HealthAnalytics IPS - Frontend Variables
# Copia a .env.local para desarrollo local
# En Vercel: configura en Settings > Environment Variables
# ============================================

# URL del backend API
# Desarrollo local:
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
# Producción (Vercel):
# NEXT_PUBLIC_API_URL=https://tu-api.vercel.app/api/v1

# Nombre de la aplicación
NEXT_PUBLIC_APP_NAME=HealthAnalytics IPS
